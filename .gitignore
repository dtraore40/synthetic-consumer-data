# -----------------------------
# R History / Session / User files
# -----------------------------

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# R Environment Variables
.Renviron


# -----------------------------
# R Build / Check / Package files
# -----------------------------

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/


# -----------------------------
# RStudio specific
# -----------------------------

# RStudio files
.Rproj.user/

# RStudio Connect folder
rsconnect/ 

# pkgdown site
#docs/


# -----------------------------
# renv (R project environment)
# -----------------------------

renv/library/
renv/staging/
renv/cache/
# keep renv.lock, activate.R, settings.json
# .Rprofile 


# -----------------------------
# R Markdown / knitr
# -----------------------------

# knitr and R markdown default cache directories
*_cache/
.cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# produced vignettes
vignettes/*.html
vignettes/*.pdf


# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.ipynb_checkpoints
env/
venv/


# -----------------------------
# Data (confidential)
# -----------------------------

# Ignore all data files
data/*
!data/.gitkeep

!data/raw/
data/raw/*
!data/raw/.gitkeep

!data/processed/
data/processed/*
!data/processed/.gitkeep

# data
data_dictionary.qmd


# -----------------------------
# results
# -----------------------------
results/*
!results/.gitkeep


# -----------------------------
# OS / Misc
# -----------------------------
.DS_Store
Thumbs.db


# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
# Ignores tokens generated during API connections
.httr-oauth 

# translation temp files during the translation of R packages
po/*~


# -----------------------------
# Oth
# -----------------------------

# test
test2.qmd

.gitignore







